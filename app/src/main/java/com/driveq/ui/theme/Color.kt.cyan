package com.uberfilter.ui.theme

import androidx.compose.ui.graphics.Color

// ── Família 1: Cyan — Destaque, botões, indicadores ativos ─────────────────────
val WarmYellow        = Color(0xFF0097A7)   // Cyan 700 – tom encorpado com bom contraste sobre claro
val WarmYellowDim     = Color(0xFF006064)   // Cyan 900 (azul petróleo) – estado pressionado / variante
val WarmYellowGlow    = Color(0x330097A7)   // brilho sutil (alpha baixo)
val OnWarmYellow      = Color(0xFFFFFFFF)   // texto sobre botões preenchidos (branco)

// ── Família 2: Light Cyan — Containers, superfícies destacadas ───────────────
val LightYellowContainer  = Color(0xFFE0F7FA)   // container primary (Cyan 50)
val OnLightYellowContainer = Color(0xFF006064)   // texto sobre container (Cyan 900 / azul petróleo)
val LightYellowSurface    = Color(0xFFB2EBF2)   // cyan claro – cards destacados, chips (Cyan 100)
val LightYellowBg         = Color(0xFFE5F6F8)   // cyan muito suave – seções com destaque sutil

// ── Família 3: Neutros Frios — Fundo, texto, bordas ───────────────────────────
val WarmWhite         = Color(0xFFF5FAFB)   // fundo principal (branco com leve tom cyan)
