val WarmOnBg          = Color(0xFF1A1F20)   // texto principal (quase preto com tom frio)
val WarmOnSurfaceVariant = Color(0xFF5F6A6C) // texto secundário (cinza azulado)
val WarmPlaceholder   = Color(0xFF8F9A9C)   // placeholder / hint
val WarmOutline       = Color(0xFFC8D4D6)   // bordas (cinza cyan)
val WarmOutlineVariant = Color(0xFFDEE6E8)  // bordas sutis / divisores leves

